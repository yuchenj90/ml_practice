    "class ViT(nn.Module):\n",
    "    def __init__(self, d_model, n_heads, n_blocks, d_patch, dropout=0.1, n_channels=3, height=32, width=32):\n",
    "        super().__init__()\n",
    "        assert height % d_patch == 0, f\"Error: {height} is not divisible by {d_patch}\"\n",
    "        assert width % d_patch == 0, f\"Error: {width} is not divisible by {d_patch}\"\n",
    "        self.d_model = d_model\n",
    "        self.n_heads = n_heads \n",
    "        self.n_blocks = n_blocks\n",
    "        self.d_patch = d_patch\n",
    "        self.dropout = dropout\n",
    "        self.n_c = n_channels\n",
    "        self.h = height\n",
    "        self.w = width\n",
    "        self.n_h = self.h // self.d_patch\n",
    "        self.n_w = self.w // self.d_patch\n",
    "        self.pretrain = pretrain\n",
    "\n",
    "        transformer_layers = [Transformer(self.d_model, self.n_heads, self.dropout) for _ in range(self.n_blocks)]\n",
    "        self.transformer_blocks = nn.Sequential(*transformer_layers)\n",
    "        self.embedding_layer = nn.Linear(self.n_c * self.d_patch**2, self.d_model)\n",
    "        self.cls_emb = nn.Parameter(torch.rand(1, self.d_model))\n",
    "        self.pos_emb = nn.Parameter(torch.rand((self.n_h*self.n_w + 1, self.d_model)))\n",
    "        self.clf_head = nn.Sequential(nn.Linear(self.d_model, self.d_model), nn.GELU(), nn.Dropout(self.dropout))\n",
    "        \n",
    "            \n",
    "    def forward(self, x):\n",
    "        '''\n",
    "            x is a batch of image, with shape (N, 3, 32, 32)\n",
    "        '''\n",
    "        bs, c, h, w = x.shape[0], x.shape[1], x.shape[2], x.shape[3]\n",
    "        n_h = h // self.d_patch\n",
    "        n_w = w // self.d_patch\n",
    "        x = x.permute(0,2,3,1)  # (bs, h, w, c)\n",
    "        x = x.reshape((bs, n_h, self.d_patch, n_w, self.d_patch, c)).transpose(2, 3)   # (bs, n_h, n_w, d_patch, d_patch, c)\n",
    "        x = x.reshape((bs, n_h*n_w, c*self.d_patch**2)) \n",
    "        x = self.embedding_layer(x)  # (bs, n_h*n_w, d_model)\n",
    "        y = self.cls_emb(y).repeat(bs,1,1) # (bs, 1, d_model)\n",
    "        x = torch.cat([y, x], dim=1)  # (bs, n_h*n_w + 1, d_model)\n",
    "        x = x + self.pos_emb.unsqueeze(0) \n",
    "\n",
    "        x = self.transformer_blocks(x) # (bs, n_h*n_w + 1, d_model)\n",
    "        x = self.clf_head(x[:,0,:].squeeze(1)) # (bs, d_model)\n",
    "        return x\n",
    "\n",
    "    def loss(self, x, y):\n",
    "        pass"
   ]
