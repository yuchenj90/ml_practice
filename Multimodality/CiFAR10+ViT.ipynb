    "class Transformer(nn.Module):\n",
    "    def __init__(self, d_model, n_heads, dropout=0.1):\n",
    "        super().__init__()\n",
    "        self.d_model = d_model\n",
    "        self.n_heads = n_heads\n",
    "        self.dropout = dropout\n",
    "        \n",
    "        self.attention_layer = SelfAttention(self.d_model, self.n_heads)\n",
    "        self.mlp_layer = nn.Sequential(\n",
    "            nn.Linear(self.d_model, self.d_model*4),\n",
    "            nn.GELU(),\n",
    "            nn.Dropout(dropout),\n",
    "            nn.Linear(self.d_model*4, self.d_model),\n",
    "            nn.GELU(),\n",
    "            nn.Dropout(dropout),\n",
    "        )\n",
    "        self.attention_ln = nn.LayerNorm(self.d_model)\n",
    "        self.mlp_ln = nn.LayerNorm(self.d_model)\n",
    "        \n",
    "    def forward(self, x):\n",
    "        x = self.attention_layer(self.attention_ln(x)) + x\n",
    "        x = self.mlp_layer(self.mlp_ln(x)) + x\n",
    "        return x"
   ]
