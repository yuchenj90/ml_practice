    "import torch\n",
    "from datasets import load_dataset\n",
    "from torchvision import transforms\n",
    "from torch.utils.data import DataLoader\n",
    "\n",
    "def get_imagenet_streamer(batch_size=64):\n",
    "    # 1. Define the preprocessing pipeline\n",
    "    # ImageNet models typically expect 224x224 normalized images\n",
    "    preprocess = transforms.Compose([\n",
    "        transforms.Resize(256),\n",
    "        transforms.CenterCrop(224),\n",
    "        transforms.ToTensor(),\n",
    "        transforms.Normalize(\n",
    "            mean=[0.485, 0.456, 0.406], \n",
    "            std=[0.229, 0.224, 0.225]\n",
    "        ),\n",
    "    ])\n",
    "\n",
    "    # 2. Load the dataset in streaming mode\n",
    "    # 'split' can be 'train' or 'validation'\n",
    "    dataset = load_dataset(\n",
    "        \"ILSVRC/imagenet-1k\", \n",
    "        split=\"train\", \n",
    "        streaming=True, \n",
    "        trust_remote_code=True\n",
    "    )\n",
    "\n",
    "    # 3. Define a transformation function for the stream\n",
    "    def transform_fn(examples):\n",
    "        # Convert grayscale to RGB and apply transforms\n",
    "        examples[\"pixel_values\"] = [\n",
    "            preprocess(image.convert(\"RGB\")) for image in examples[\"image\"]\n",
    "        ]\n",
    "        return examples\n",
    "\n",
    "    # Apply the transform to the stream\n",
    "    dataset = dataset.map(transform_fn, batched=True)\n",
    "    \n",
    "    # Remove the raw 'image' column to save memory\n",
    "    dataset = dataset.remove_columns([\"image\"])\n",
    "    \n",
    "    # Set format for PyTorch\n",
    "    dataset = dataset.with_format(\"torch\")\n",
    "\n",
    "    # 4. Create the DataLoader\n",
    "    # Note: shuffle(buffer_size=...) is used for streaming shuffle\n",
    "    shuffled_dataset = dataset.shuffle(seed=42, buffer_size=1000)\n",
    "    \n",
    "    loader = DataLoader(shuffled_dataset, batch_size=batch_size)\n",
    "    \n",
    "    return loader"
   ]
  },
