    "class SelfAttention(nn.Module):\n",
    "    def __init__(self, d_model, n_heads):\n",
    "        super().__init__()\n",
    "        assert d_model % n_heads == 0, f\"Error: {d_model} is not divisible by {n_heads}\"\n",
    "        self.d_model = d_model\n",
    "        self.n_heads = n_heads\n",
    "        self.d_h = d_model // n_heads\n",
    "\n",
    "        self.Wk = nn.Linear(self.d_model, self.d_model)\n",
    "        self.Wq = nn.Linear(self.d_model, self.d_model)\n",
    "        self.Wv = nn.Linear(self.d_model, self.d_model)\n",
    "        # self.Wo = nn.Linear(self.d_model, self.d_model)\n",
    "\n",
    "    def forward(self, x):\n",
    "        '''\n",
    "            x has shape (N, seq_len, d_model)\n",
    "        '''\n",
    "        bs, l = x.shape[0], x.shape[1]\n",
    "        \n",
    "        key = self.Wk(x).view((bs, l, self.n_heads, self.d_h)).transpose(1,2)\n",
    "        query = self.Wq(x).view((bs, l, self.n_heads, self.d_h)).transpose(1,2)\n",
    "        value = self.Wv(x).view((bs, l, self.n_heads, self.d_h)).transpose(1,2)\n",
    "\n",
    "        kdotq = key @ query.transpose(-1,-2) / (self.d_h**0.5) # (N, n_heads, seq_len, seq_len)\n",
    "        att_score = kdotq.softmax(dim=-1)\n",
    "        out = att_score @ value # (N, n_head, seq_len, d_h)\n",
    "        out = out.transpose(1,2) # (N, seq_len, n_head, d_h)\n",
    "        out = out.reshape((bs, l, self.d_model)) # (N, seq_len, d_model)\n",
    "        # out = self.Wo(out)\n",
    "        \n",
    "        return out"
   ]
  },
